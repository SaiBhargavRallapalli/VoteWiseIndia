# Dependencies — rebuilt inside the image
node_modules/
npm-debug.log*

# Test / coverage artefacts — not needed at runtime
coverage/
*.test.js
jest.config.*

# Secrets — must NEVER enter the image
.env
.env.*
!.env.example

# VCS & editor
.git/
.gitignore
.gitattributes
.vscode/
.idea/
.DS_Store

# Docs / meta (kept in repo, not in image)
README.md
*.md

# CI / local dev
.github/
Dockerfile.dev
docker-compose*.yml
