# ──────────────────────────────────────────────────────────────
# VoteWise India — Environment Variables
# Copy this file to `.env` and fill in your own values.
# NEVER commit the real `.env` file to version control.
# ──────────────────────────────────────────────────────────────

# ── Google Cloud APIs ──────────────────────────────────────────
# All Google Cloud APIs use a single key from the same GCP project.
# Enable these APIs in Google Cloud Console:
#   - Generative Language API (Gemini)
#   - Cloud Translation API
#   - Cloud Text-to-Speech API
#   - Cloud Vision API
#   - Cloud Natural Language API
#   - BigQuery API (optional)

# Google Gemini API — https://aistudio.google.com/apikey
# Used for: AI chat assistant + Natural Language Analysis + translation fallback
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud API Key — https://console.cloud.google.com/apis/credentials
# Used for: Cloud Translation, Text-to-Speech, Vision APIs
# Can be the same key as GEMINI_API_KEY if enabled on the same project
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Server port (Cloud Run injects its own PORT env var in production)
PORT=8080

# CORS — restrict to your deployed frontend origin in production; leave as * for local dev
ALLOWED_ORIGIN=*

# ── Firebase (optional — enables quiz leaderboard + auth) ──────
# Create a project at https://console.firebase.google.com
# Settings ▸ General ▸ Your apps ▸ Web app ▸ SDK config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── BigQuery (optional — enables analytics export) ─────────────
# Dataset name for analytics export (creates tables automatically)
BIGQUERY_DATASET=votewise_analytics

# ── Google Analytics 4 (optional) ──────────────────────────────
GA_MEASUREMENT_ID=
